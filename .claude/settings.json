{
  "model": "opus[1m]",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo check:*)",
      "Bash(cargo clippy:*)",
      "Bash(bun test:*)",
      "Bash(sed:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(awk:*)",
      "Bash(echo:*)",
      "Bash(git show:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git blame:*)",
      "Bash(git status:*)",
      "Bash(git ls-files:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-tests-written.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-tests.sh"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-workflow-sync.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'hits=$(grep -rnE \"^use sicompass_(filebrowser|settings|chatclient|emailclient|webbrowser|tutorial|remote|sales_demo)::\" \"$CLAUDE_PROJECT_DIR\"/src/sicompass/src 2>/dev/null); if [ -n \"$hits\" ]; then echo \"SDK boundary violation: app code must not import lib crates directly. All communication goes through sicompass-sdk and sicompass-builtins. Offending imports:\" >&2; echo \"$hits\" >&2; exit 2; fi'"
          }
        ]
      }
    ]
  }
}
